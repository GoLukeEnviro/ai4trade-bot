# Secret Backend: env (default), keyring, vault
SECRET_BACKEND=env

# Secrets (loaded through provider)
AI4TRADE_TOKEN=
CLAUDE_API_KEY=
LLM_API_KEY=

# LLM Configuration
CLAUDE_MODEL=claude-sonnet-4-5-20250929
LLM_PROVIDER=claude
LLM_MODEL=
LLM_BASE_URL=

# Signal framework
ASSETS=BTC/USDT,ETH/USDT,SOL/USDT
DATA_INTERVAL=60
SENTIMENT_INTERVAL=300
HEARTBEAT_INTERVAL=30
CONFIDENCE_THRESHOLD=60

# Runtime
LOG_LEVEL=INFO
MAX_SIGNAL_QUEUE=50
METRICS_PORT=9090
DB_PATH=storage/bot.db

# Vault (only needed if SECRET_BACKEND=vault)
# VAULT_URL=
# VAULT_TOKEN=
