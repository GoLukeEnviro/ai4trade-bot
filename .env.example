# Secret Backend: env (default), keyring, vault
SECRET_BACKEND=env

# Secrets (loaded through provider)
AI4TRADE_TOKEN=
CLAUDE_API_KEY=
LLM_API_KEY=

# LLM Configuration
CLAUDE_MODEL=claude-sonnet-4-5-20250929
LLM_PROVIDER=claude
LLM_MODEL=
LLM_BASE_URL=

# Trading
TRADING_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT
DATA_INTERVAL=60
SENTIMENT_INTERVAL=300
HEARTBEAT_INTERVAL=30

# Risk
MAX_POSITION_PCT=0.10
MAX_DRAWDOWN_PCT=0.20
MAX_OPEN_POSITIONS=3
CONFIDENCE_THRESHOLD=60

# Runtime
MODE=dry_run
LOG_LEVEL=INFO
MAX_SIGNAL_QUEUE=50

# Vault (only needed if SECRET_BACKEND=vault)
# VAULT_URL=
# VAULT_TOKEN=
